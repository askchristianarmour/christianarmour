VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Use the "anon" / "public" key from Supabase → Project Settings → API
# It usually starts with eyJ... (JWT format)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public site URL for SEO (canonical links, sitemap, Open Graph)
# Set to your custom domain in production, e.g. https://christianarmour.com
VITE_SITE_URL=https://christianarmour.vercel.app
